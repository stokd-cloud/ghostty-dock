    "mobile.troubleshooting.commonIssues": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Common Issues"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "よくある問題"
          }
        }
      }
    },
    "mobile.troubleshooting.issue1.fix1": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Confirm Mac and iPhone use the same cmux account."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "MacとiPhoneが同じcmuxアカウントにサインインしていることを確認します。"
          }
        }
      }
    },
    "mobile.troubleshooting.issue1.fix2": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "On Mac, allow cmux in System Settings > Privacy & Security > Local Network."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Macで、システム設定 > プライバシーとセキュリティ > ローカルネットワークのcmuxを許可します。"
          }
        }
      }
    },
    "mobile.troubleshooting.issue1.fix3": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Tap Rescan QR, then pair again if needed."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "「QRを再スキャン」をタップし、必要ならもう一度ペアリングします。"
          }
        }
      }
    },
    "mobile.troubleshooting.issue1.fix4": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Use the same network or Tailscale on both devices."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "両方のデバイスを同じネットワークまたはTailscaleに接続します。"
          }
        }
      }
    },
    "mobile.troubleshooting.issue1.title": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "My computer doesn't show up"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "コンピュータが表示されない"
          }
        }
      }
    },
    "mobile.troubleshooting.issue2.fix1": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Open the selected cmux build on your Mac, then tap Retry."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "選択したcmuxビルドをMacで開いてから「再試行」をタップします。"
          }
        }
      }
    },
    "mobile.troubleshooting.issue2.fix2": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "If it stays stuck, remove the computer and pair again."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "続く場合はコンピュータを削除して、もう一度ペアリングします。"
          }
        }
      }
    },
    "mobile.troubleshooting.issue2.title": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Stuck on Still loading"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "「まだ読み込み中」から進まない"
          }
        }
      }
    },
    "mobile.troubleshooting.issue3.fix1": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Enable agent notifications in cmux Settings > Notifications."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "cmuxの設定 > 通知でエージェント通知を有効にします。"
          }
        }
      }
    },
    "mobile.troubleshooting.issue3.fix2": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Allow cmux notifications in iOS Settings."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "iOS設定でcmuxの通知を許可します。"
          }
        }
      }
    },
    "mobile.troubleshooting.issue3.fix3": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Notifications forward only while you're away from your Mac."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "通知はMacから離れている間だけ転送されます。"
          }
        }
      }
    },
    "mobile.troubleshooting.issue3.title": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Notifications don't arrive"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "通知が届かない"
          }
        }
      }
    },
    "mobile.troubleshooting.issue4.fix1": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Update cmux on the Mac; Run Diagnostics should show Voice Mode supported."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Macのcmuxをアップデートします。「診断を実行」で音声モード対応を確認できます。"
          }
        }
      }
    },
    "mobile.troubleshooting.issue4.fix2": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Click a terminal pane on the Mac before using the mic."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "マイクを使う前にMacでターミナルペインをクリックします。"
          }
        }
      }
    },
    "mobile.troubleshooting.issue4.title": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Voice Mode is missing or grayed out"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "音声モードがない、またはグレー表示される"
          }
        }
      }
    },
    "mobile.troubleshooting.issue5.fix1": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Voice Mode targets the pane currently focused on the Mac."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "音声モードはMacで現在フォーカスされているペインを対象にします。"
          }
        }
      }
    },
    "mobile.troubleshooting.issue5.fix2": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Click the destination pane before speaking and watch the Target card update."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "話す前に送信先ペインをクリックし、ターゲットカードの更新を確認します。"
          }
        }
      }
    },
    "mobile.troubleshooting.issue5.title": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Voice text goes to the wrong pane"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "音声テキストが違うペインに入る"
          }
        }
      }
    },
    "mobile.troubleshooting.issue6.fix1": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Keep about 483 MB free and use a stable connection."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "約483 MBの空き容量と安定した接続を用意します。"
          }
        }
      }
    },
    "mobile.troubleshooting.issue6.fix2": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Cancel and retry the download."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "キャンセルしてからダウンロードを再試行します。"
          }
        }
      }
    },
    "mobile.troubleshooting.issue6.fix3": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "If transcription misbehaves, delete the model in Settings > Voice and download again."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "文字起こしがおかしい場合は、設定 > 音声でモデルを削除して再ダウンロードします。"
          }
        }
      }
    },
    "mobile.troubleshooting.issue6.title": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Parakeet download fails"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Parakeetのダウンロードに失敗する"
          }
        }
      }
    },
    "mobile.troubleshooting.issue7.fix1": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Allow Microphone for cmux in iOS Settings > Privacy & Security."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "iOS設定 > プライバシーとセキュリティでcmuxのマイクを許可します。"
          }
        }
      }
    },
    "mobile.troubleshooting.issue7.fix2": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "For Apple engine, allow Speech Recognition too, then retry the mic."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Appleエンジンでは音声認識も許可してから、もう一度マイクを試します。"
          }
        }
      }
    },
    "mobile.troubleshooting.issue7.title": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Microphone or dictation doesn't work"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "マイクまたは音声入力が動かない"
          }
        }
      }
    },
    "mobile.troubleshooting.issue8.fix1": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Check Connection in Run Diagnostics."
          }
