    "mobile.setupHelp.title": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Set Up Computer"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
