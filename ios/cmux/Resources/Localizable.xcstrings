    "mobile.troubleshooting.issue8.fix2": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Toggle Wi-Fi or switch networks to force a reconnect."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Wi-Fiを切り替えるかネットワークを変更して再接続させます。"
          }
        }
      }
    },
    "mobile.troubleshooting.issue8.fix3": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "If it stays down, reconnect from the computer picker."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "復旧しない場合はコンピュータピッカーから再接続します。"
