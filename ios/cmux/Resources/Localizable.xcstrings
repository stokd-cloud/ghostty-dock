    "mobile.settings.privacy.terminal": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Terminal data flows only between your devices through your cmux account connection."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ターミナルデータは、cmuxアカウント接続を通じてあなたのデバイス間でのみ流れます。"
